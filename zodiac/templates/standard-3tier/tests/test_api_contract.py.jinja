"""Contract tests for the generated API skeleton."""


async def test_health_endpoint_sets_request_id_header(client):
    """Health endpoint should include the standard request ID header."""
    response = await client.get("/api/v1/health")

    assert response.status_code == 200
    assert "X-Request-ID" in response.headers
    assert len(response.headers["X-Request-ID"]) == 36


async def test_items_list_uses_standard_paged_response(client):
    """List endpoint should return the wrapped paged response shape."""
    response = await client.get("/api/v1/items?page=1&size=20")

    assert response.status_code == 200
    assert response.json() == {
        "code": 0,
        "message": "Success",
        "data": {
            "items": [],
            "total": 0,
            "page": 1,
            "size": 20,
        },
    }


async def test_item_not_found_uses_standard_error_response(client):
    """Missing items should use the unified error response contract."""
    response = await client.get("/api/v1/items/1")

    assert response.status_code == 404
    assert response.json() == {
        "code": 404,
        "message": "Item id '1' not found",
        "data": None,
    }
