from loguru import logger
from zodiac_core.http import ZodiacClient, translate_upstream_errors


class GitHubClient:
    """GitHub API client using ZodiacClient for automatic Trace ID injection."""

    def __init__(self, client: ZodiacClient) -> None:
        self.client = client

    @translate_upstream_errors(service="github")
    async def fetch_homepage(self) -> dict:
        """Fetch GitHub API root data."""
        response = await self.client.get("/")
        response.raise_for_status()
        logger.debug(f"Fetched GitHub API root, status={response.status_code}")
        return response.json()
